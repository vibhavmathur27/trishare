# --- Database (Neon Postgres) ---
# Create a new Neon project, then paste the pooled connection string here.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require
# Neon also gives you a "direct" (non-pooled) connection string — Prisma needs
# this one for schema changes even though the app runs on the pooled URL above.
DIRECT_URL=postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require

# --- File storage (Vercel Blob) ---
# Vercel dashboard -> Storage -> Create -> Blob -> copy the token it gives you.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- Site password (shared, single password gate) ---
SITE_PASSWORD=choose-a-password

# --- AI provider keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# --- Optional: override default model names if a provider deprecates one ---
# CLAUDE_MODEL=claude-sonnet-5
# OPENAI_MODEL=gpt-4.1
# GEMINI_MODEL=gemini-2.5-flash
