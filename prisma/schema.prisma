generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model EmailLog {
  id          String    @id @default(cuid())
  name        String
  company     String    @default("")
  role        String    @default("")
  email       String
  subject     String    @default("")
  dateSent    DateTime
  status      String    @default("sent") // sent | replied
  resendCount Int       @default(0)
  notes       String    @default("")
  draft       String?   @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CallLog {
  id           String    @id @default(cuid())
  name         String
  company      String    @default("")
  role         String    @default("")
  phone        String
  dateCalled   DateTime
  outcome      String    @default("connected") // connected | no_answer | voicemail | scheduled
  nextFollowUp DateTime?
  notes        String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Application {
  id             String          @id @default(cuid())
  company        String
  role           String
  source         String          @default("")
  dateApplied    DateTime
  jobDescription String          @default("")
  status         String          @default("applied") // applied | interview | offer | rejected
  notes          String          @default("")
  resumeVersions ResumeVersion[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ResumeVersion {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  originalName  String
  blobUrl       String
  uploadedAt    DateTime    @default(now())
}
